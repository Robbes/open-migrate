{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@openmig/shared": ["./packages/shared/src/index.ts"],
      "@openmig/shared/*": ["./packages/shared/src/*"],
      "@openmig/ledger": ["./packages/ledger/src/index.ts"],
      "@openmig/ledger/*": ["./packages/ledger/src/*"],
      "@openmig/core": ["./packages/core/src/index.ts"],
      "@openmig/core/*": ["./packages/core/src/*"],
      "@openmig/connectors": ["./packages/connectors/src/index.ts"],
      "@openmig/connectors/*": ["./packages/connectors/src/*"],
      "@openmig/engines": ["./packages/engines/src/index.ts"],
      "@openmig/engines/*": ["./packages/engines/src/*"],
      "@openmig/scheduler": ["./packages/scheduler/src/index.ts"],
      "@openmig/scheduler/*": ["./packages/scheduler/src/*"],
      "@openmig/provisioner": ["./packages/provisioner/src/index.ts"],
      "@openmig/provisioner/*": ["./packages/provisioner/src/*"]
    }
  }
}

# Open Migration Stack - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=openmigrate
POSTGRES_PASSWORD=openmigrate_password
POSTGRES_DB=openmigrate
POSTGRES_PORT=5432

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# ============================================
# Trigger.dev Configuration
# ============================================
TRIGGER_ENCRYPTION_KEY=your-trigger-encryption-key-min-32-chars
TRIGGER_LOGIN_SECRET=your-trigger-login-secret-min-32-chars
TRIGGER_API_KEY=your-trigger-api-key
TRIGGER_PORT=3090

# ============================================
# Mollie Payment Gateway
# ============================================
# Get these from https://www.mollie.com/dashboard/settings/profile
MOLLIE_API_KEY=your_mollie_api_key
MOLLIE_WEBHOOK_SECRET=your_mollie_webhook_secret

# ============================================
# Application URLs
# ============================================
WEB_URL=http://localhost:3123
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3123

# ============================================
# API Configuration
# ============================================
API_PORT=3001
NODE_ENV=development

# ============================================
# Worker Configuration
# ============================================
IMAP_TIMEOUT=300
JMAP_TIMEOUT=300

# ============================================
# Optional: External Services
# ============================================
# S3_BUCKET=your-s3-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-s3-access-key
# S3_SECRET_KEY=your-s3-secret-key

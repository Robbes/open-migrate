# Self-host edition — environment template (workplan 0010 T3/T4).
# Copy to `.env` next to compose.yml (compose auto-loads it):
#   cp deploy/selfhost/selfhost.env.example deploy/selfhost/.env
#   chmod 600 deploy/selfhost/.env
# NEVER commit a filled-in copy. Real secrets belong on the host only (see the
# permissions/rotation guidance in docs/selfhost-quickstart.md).

# ---- Bundled Postgres ----------------------------------------------------
# Single-tenant: the app connects as this owner role (RLS is unused here). The
# DB is only reachable on the internal compose network — it is never published.
POSTGRES_USER=openmigrate
# REQUIRED — compose refuses to start without it. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=
POSTGRES_DB=openmigrate

# ---- Appliance networking ------------------------------------------------
# The status/health endpoint. By default it binds to localhost only; set
# SELFHOST_BIND=0.0.0.0 to expose it on the LAN (behind your own firewall).
SELFHOST_BIND=127.0.0.1
SELFHOST_PORT=8080

# Image tag to run. `edge` is the rolling build; pin to a released `stable`
# tag (or a digest) for production — see the channels note in the quickstart.
SELFHOST_IMAGE=ghcr.io/robbes/open-migrate-selfhost:edge

# ---- Connection credentials ----------------------------------------------
# Your mapping JSONs reference secrets by ENV VAR NAME (tokenFromEnv /
# passwordFromEnv), never inline. Define those variables here so the app can
# read them at run time. Names are yours to choose — match them in the mapping.
# Examples (uncomment + set to match deploy/selfhost/config/*.json):
#   SOURCE_IMAP_PASSWORD=
#   SOURCE_OAUTH_TOKEN=
#   TARGET_JMAP_PASSWORD=

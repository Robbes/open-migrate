# Managed edition — environment template.
# Copy to `.env` next to managed.yml (compose auto-loads it), or pass explicitly:
#   docker compose --env-file managed.env.example -f managed.yml up
# NEVER commit a filled-in copy — real secrets belong in a vault / the host only.

# ---- Postgres (ledger) ---------------------------------------------------
# POSTGRES_USER is the DB owner: used for migrations and the demo seed. In the
# postgres image the bootstrap user is a SUPERUSER and therefore bypasses RLS —
# the application must NOT use it for tenant data (see APP_DB_* below).
POSTGRES_USER=openmigrate
POSTGRES_PASSWORD=change-me-openmigrate
POSTGRES_DB=openmigrate
POSTGRES_PORT=5432

# ---- Application DB role (RLS enforcement) -------------------------------
# Non-owner role created by migration 0009. The API and worker connect through
# this role via APP_DATABASE_URL so row-level security is always enforced.
# Change the password from the migration default before any real deployment.
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password

# ---- Auth ----------------------------------------------------------------
# HS256 secret for local JWTs. The seed signs demo tokens with this exact value,
# so the API and the seed run MUST share it. (Managed SSO via JWKS uses
# JWT_ISSUER/JWT_AUDIENCE instead — leave JWT_SECRET unset in that mode.)
JWT_SECRET=change-this-in-production
JWT_EXPIRY=24h

# Encrypts stored connection credentials (create-mapping + worker). 32 bytes:
# 64 hex chars or 44 base64 chars. Generate: openssl rand -hex 32
# The API and worker MUST share this value. Rotating it strands existing secrets.
SECRET_ENCRYPTION_KEY=

# ---- Trigger.dev (self-host orchestration) -------------------------------
TRIGGER_PORT=3090
TRIGGER_API_KEY=change-me-trigger-api-key
TRIGGER_ENCRYPTION_KEY=change-me-32-byte-encryption-key
TRIGGER_LOGIN_SECRET=change-me-login-secret

# ---- Billing (Mollie test mode — T5, optional) ---------------------------
# Leave blank until billing is wired end-to-end. Use test-mode keys only.
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=

# ---- Ports / URLs --------------------------------------------------------
API_PORT=3001
WEB_PORT=3123
CORS_ORIGIN=http://localhost:3123
WEB_URL=http://localhost:3123
API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3123/api
VITE_AUTH_URL=http://localhost:3123/auth
NODE_ENV=production

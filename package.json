{
  "name": "sovereign-migration-stack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "imap-simple": "^5.1.0",
    "jmap-jam": "^0.13.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/imap-simple": "^4.2.10",
    "@types/node": "^26.1.0",
    "@types/pg": "^8",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "10.6.0",
    "pg": "^8",
    "prettier": "3.9.4",
    "tsx": "^4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "4.1.9"
  }
}

{
  "tenantId": "00000000-0000-4000-8000-000000000001",
  "mappingId": "11111111-1111-4111-8111-111111111111",
  "schedule": { "cron": "* * * * *" },
  "source": {
    "type": "imap-oauth2",
    "host": "host.docker.internal",
    "port": 143,
    "user": "source@dev.local",
    "auth": { "kind": "login", "passwordFromEnv": "SOURCE_IMAP_PASSWORD" }
  },
  "target": {
    "type": "jmap",
    "baseUrl": "http://host.docker.internal:8080/.well-known/jmap",
    "user": "target@dev.local",
    "auth": { "kind": "basic", "passwordFromEnv": "TARGET_JMAP_PASSWORD" }
  }
}

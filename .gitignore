# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Test coverage
coverage/
.nyc_output/

# Test logs (durable failure diagnostics)
test-logs/

# Temporary files
tmp/
temp/
*.tmp

# npm lockfile (pnpm is used instead)
package-lock.json
yarn.lock

# Self-host bundle: real mapping configs are operator-provided and must never be
# shipped as a committed default (the appliance auto-loads every *.json here).
# Only the *.example template is tracked. Test fixtures live under test/e2e/.
deploy/selfhost/config/*.json
